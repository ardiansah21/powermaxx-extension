{
  "name": "powermaxx-extension",
  "displayName": "Powermaxx",
  "version": "0.0.1",
  "description": "Powermaxx Scraping & Automation Engine",
  "author": "Ardiansah email.ardi21@gmail.com",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "check:bridge-regression": "node scripts/check-bridge-regression.mjs",
    "check:single-run-centric": "node scripts/check-single-run-centric.mjs",
    "check:worker-durability": "node scripts/test-worker-loop-durability.mjs",
    "verify": "npm run check:bridge-regression && npm run check:single-run-centric && npm run check:worker-durability && npx tsc --noEmit && npm run build"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage",
      "tabs",
      "scripting",
      "activeTab"
    ],
    "host_permissions": [
      "https://seller.shopee.co.id/*",
      "https://*.shopee.co.id/*",
      "https://seller-id.tokopedia.com/*"
    ],
    "optional_host_permissions": [
      "https://*/*",
      "http://*/*"
    ]
  }
}
